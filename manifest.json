{
  "manifest_version": 3,
  "name": "Smart Tab Manager",
  "version": "1.0.0",
  "description": "Understand why your tabs exist",

  "permissions": [
    "tabs",
    "storage",
    "activeTab"
  ],

  "host_permissions": [
    "https://api.groq.com/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "public/popup.html",
    "default_title": "Smart Tab Manager"
  },

  "options_page": "public/options.html",

  "commands": {
    "_execute_action": {
      "suggested_key": {
        "default": "Ctrl+Shift+S"
      },
      "description": "Open Smart Tab Manager"
    }
  }
}